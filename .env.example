# LINE Bot 設定
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# 資料庫設定
DATABASE_URL=mysql+pymysql://linebot:your_db_password@localhost/linebot

# 管理後台密碼
ADMIN_PASSWORD=your_admin_password

# 應用程式設定
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ── Dify AI 整合（feature/dify-integration 分支） ─────────────────
# 是否啟用 Dify AI 回覆（true = 走 Dify；false = 走現有 Q&A 比對）
USE_DIFY=false

# Dify Chat API 端點（Dify App 的 API base URL）
DIFY_API_URL=http://localhost:8080/v1

# Dify App API Key（從 Dify 後台 → 你的 App → API Access 取得）
DIFY_API_KEY=your-dify-app-api-key
