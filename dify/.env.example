# ── Dify Docker 設定 ───────────────────────────────────────────────
# 複製此檔為 dify/.env 並填入實際值

# Dify 對外 Port（預設 8080，避開 LINE Bot 的 port 80）
EXPOSE_DIFY_PORT=8080

# Dify 安全金鑰（請換成隨機字串，可用：openssl rand -hex 32）
DIFY_SECRET_KEY=your-secret-key-change-this

# PostgreSQL 密碼
DIFY_DB_PASSWORD=difyai123456

# Redis 密碼
DIFY_REDIS_PASSWORD=difyai123456

# Weaviate API Key
DIFY_WEAVIATE_API_KEY=WVF5YThaHlkYwhGUSmCRgsX3

# 向量資料庫選擇：weaviate（預設）/ pgvector / qdrant
DIFY_VECTOR_STORE=weaviate

# ── LINE Bot 呼叫 Dify 的設定（填入 /opt/linebot/.env） ────────────

# 是否啟用 Dify AI 回覆（true = 走 Dify；false = 走現有 Q&A 比對）
USE_DIFY=false

# Dify Chat API 端點（Dify App 的 API URL，從 Dify 後台取得）
DIFY_API_URL=http://localhost:8080/v1

# Dify App API Key（從 Dify 後台 → App → API 取得）
DIFY_API_KEY=your-dify-app-api-key
